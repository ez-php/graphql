{
    "name": "ez-php/graphql",
    "version": "1.6.0",
    "description": "GraphQL module for the ez-php framework — schema builder, query executor, and HTTP endpoint via webonyx/graphql-php",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andreas Uretschnig",
            "email": "andreas.uretschnig@gmail.com"
        }
    ],
    "keywords": [
        "graphql",
        "api",
        "schema",
        "query",
        "php",
        "framework",
        "ez-php"
    ],
    "homepage": "https://github.com/ez-php/graphql",
    "support": {
        "issues": "https://github.com/ez-php/graphql/issues",
        "source": "https://github.com/ez-php/graphql"
    },
    "require": {
        "php": "^8.5",
        "webonyx/graphql-php": "^15.0",
        "ez-php/contracts": "^1.0",
        "ez-php/http": "^1.0",
        "ez-php/framework": "^1.0"
    },
    "require-dev": {
        "ez-php/docker": "^1.0",
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "EzPhp\\GraphQL\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "full": "composer analyse && composer cs && composer test"
    }
}
